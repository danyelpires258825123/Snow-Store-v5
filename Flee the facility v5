        if name == "exit1" or name == "exit2" or name == "exit_a" or name == "exit_b" or
           name == "exitdoor1" or name == "exitdoor2" or name == "door_exit" or 
           name == "emergencyexit" or name == "fireexit" or name == "mainexit" then
            -- Verifica se já não foi adicionado
            local alreadyAdded = false
            for _, existing in ipairs(exits) do
                if existing == obj then
                    alreadyAdded = true
                    break
                end
            end
            if not alreadyAdded then
                table.insert(exits, obj)
            end
        end
    end
end

-- MÉTODO 3: Procura por filhos que indicam porta de saída (triggers, prompts, etc)
for _, obj in ipairs(workspace:GetDescendants()) do
    if obj:IsA("Model") or obj:IsA("Part") or obj:IsA("Folder") then
        -- Verifica se tem componentes de porta de saída
        if obj:FindFirstChild("ExitDoorTrigger") or obj:FindFirstChild("ExitZone") or 
           obj:FindFirstChild("ExitPrompt") or obj:FindFirstChild("ExitDoor") or
           obj:FindFirstChild("DoorPrompt") or obj:FindFirstChild("OpenPrompt") or
           obj:FindFirstChild("ExitPart") then
            
            local alreadyAdded = false
            for _, existing in ipairs(exits) do
                if existing == obj then
                    alreadyAdded = true
                    break
                end
            end
            if not alreadyAdded then
                table.insert(exits, obj)
            end
        end
        
        -- Verifica se tem luz de status de saída (indicador comum)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("Light") or child:IsA("SpotLight") or child:IsA("PointLight") then
                local lightName = child.Name:lower()
                if lightName:find("exit") or lightName:find("status") then
                    local alreadyAdded = false
                    for _, existing in ipairs(exits) do
                        if existing == obj then
                            alreadyAdded = true
                            break
                        end
                    end
                    if not alreadyAdded then
                        table.insert(exits, obj)
                    end
                    break
                end
            end
        end
    end
end

-- Cria highlights para todas as saídas encontradas (devem ser 2 por mapa)
for _, obj in ipairs(exits) do
    local success, hl = pcall(function()
        local h = Instance.new("Highlight")
        h.Name = "ExitESP"
        
        -- Define o Adornee corretamente
        if obj:IsA("Model") then
            h.Adornee = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart") or obj
        else
            h.Adornee = obj
        end
        
        -- COR AMARELA BRILHANTE para saídas
        h.OutlineColor = Color3.fromRGB(255, 255, 0) -- AMARELO PURO
        h.FillTransparency = 1
        h.OutlineTransparency = 0
        h.Enabled = true
        h.Parent = obj
        
        return h
    end)
    
    if success then
        exitHighlights[obj] = hl
    end
end

