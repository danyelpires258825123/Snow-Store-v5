-- =============================================
-- ESP PC - CORRIGIDO: Pega em TODOS os computadores do mapa
-- =============================================
-- FUNÇÃO SIMPLIFICADA: Detecta o status do PC pela cor da tela
local function getPCStatus(computer)
-- Procura pela parte da tela/monitor dentro do computador
local screen = nil
-- Procura em todos os descendentes por partes que parecem ser telas
for _, part in ipairs(computer:GetDescendants()) do
    if part:IsA("BasePart") then
        local name = part.Name:lower()
        -- Nomes comuns para telas/monitores em Flee the Facility
        if name:find("screen") or name:find("monitor") or name:find("display") or 
           name:find("pcscreen") or name:find("lcd") or name:find("led") then
            screen = part
            break
        end
    end
end

-- Se não encontrou pelo nome, pega a primeira parte base que encontrar
if not screen then
    for _, part in ipairs(computer:GetDescendants()) do
        if part:IsA("BasePart") then
            screen = part
            break
        end
    end
end

if screen then
    local color = screen.Color
    local r, g, b = color.R, color.G, color.B
    
    -- Verifica se é VERDE (hackeado/completo)
    -- Verde puro: G alto, R e B baixos
    if g > 0.4 and r < 0.3 and b < 0.3 then
        return "Completed"
    end
    
    -- Verifica se é VERMELHO (falhou/erro)
    -- Vermelho: R alto, G e B baixos
    if r > 0.4 and g < 0.3 and b < 0.3 then
        return "Error"
    end
    
    -- Verifica se é AZUL (disponível/normal)
    -- Azul: B alto, R e G mais baixos
    if b > 0.3 and r < 0.4 and g < 0.4 then
        return "Normal"
    end
end

-- Se não conseguiu pela cor, tenta verificar valores internos
local hacked = computer:FindFirstChild("Hacked") or computer:FindFirstChild("Completed") or computer:FindFirstChild("Done")
if hacked and hacked:IsA("ValueBase") and hacked.Value == true then
    return "Completed"
end

local progress = computer:FindFirstChild("Progress") or computer:FindFirstChild("HackProgress")
if progress and progress:IsA("ValueBase") then
    local prog = tonumber(progress.Value)
    if prog and (prog >= 100 or prog == 1) then
        return "Completed"
    elseif prog and prog > 0 then
        return "Hacking"
    end
end

local beingHacked = computer:FindFirstChild("BeingHacked") or computer:FindFirstChild("InUse")
if beingHacked and beingHacked:IsA("ValueBase") and beingHacked.Value == true then
    return "Hacking"
end

return "Normal"

end
local function updatePCHighlightColor(computer, highlight)
-- Atualiza a cor baseada no status atual
local status = getPCStatus(computer)
if status == "Completed" then
    highlight.OutlineColor = Color3.fromRGB(0, 255, 0) -- Verde brilhante quando completo
elseif status == "Error" then
    highlight.OutlineColor = Color3.fromRGB(255, 0, 0) -- Vermelho quando erro/falha
elseif status == "Hacking" then
    highlight.OutlineColor = Color3.fromRGB(255, 165, 0) -- Laranja quando sendo hackeado
else
    highlight.OutlineColor = Color3.fromRGB(0, 100, 255) -- Azul quando normal/disponível
end

return status

end
local function updatePCHighlights()
-- Limpa highlights antigos e desconecta conexões
for obj, hl in pairs(pcHighlights) do
if hl then pcall(function() hl:Destroy() end) end
end
pcHighlights = {}
for obj, conn in pairs(pcStatusConnections) do
    if conn then 
        for _, c in ipairs(conn) do
            pcall(function() c:Disconnect() end)
        end
    end
end
pcStatusConnections = {}

if not espStates.PC then return end

-- Procura TODOS os computadores no workspace (sem verificação restritiva)
local computers = {}

-- Procura diretamente por objetos com nomes de computadores
for _, obj in ipairs(workspace:GetDescendants()) do
    if obj:IsA("Model") or obj:IsA("Part") or obj:IsA("Folder") then
        local name = obj.Name:lower()
        
        -- Nomes de computadores no Flee the Facility - MAIS AMPLIO
        if name:find("computer") or name:find("pc") or name:find("hack") or 
           name == "computertable" or name == "computer" or name == "pc" or 
           name:find("terminal") or name:find("station") then
            
            -- Verifica se tem pelo menos uma parte (para ter algo para destacar)
            local hasPart = false
            for _, child in ipairs(obj:GetDescendants()) do
                if child:IsA("BasePart") then
                    hasPart = true
                    break
                end
            end
            
            if hasPart then
                table.insert(computers, obj)
            end
        end
    end
end

-- Cria highlights para todos os computadores encontrados
for _, computer in ipairs(computers) do
    local success, hl = pcall(function()
        local h = Instance.new("Highlight")
        h.Name = "PCESP"
        h.Adornee = computer
        h.FillTransparency = 1
        h.OutlineTransparency = 0
        h.Enabled = true
        h.Parent = computer
        
        -- Define cor inicial
        updatePCHighlightColor(computer, h)
        
        -- Monitora mudanças de cor em todas as partes
        local connections = {}
        
        for _, child in ipairs(computer:GetDescendants()) do
            if child:IsA("BasePart") then
                local conn = child:GetPropertyChangedSignal("Color"):Connect(function()
                    if pcHighlights[computer] and pcHighlights[computer].Parent then
                        updatePCHighlightColor(computer, pcHighlights[computer])
                    end
                end)
                table.insert(connections, conn)
            end
            
            if child:IsA("ValueBase") then
                local conn = child.Changed:Connect(function()
                    if pcHighlights[computer] and pcHighlights[computer].Parent then
                        updatePCHighlightColor(computer, pcHighlights[computer])
                    end
                end)
                table.insert(connections, conn)
            end
        end
        
        -- Monitora novos filhos
        local childAddedConn = computer.DescendantAdded:Connect(function(desc)
            task.wait(0.1)
            if pcHighlights[computer] and pcHighlights[computer].Parent then
                updatePCHighlightColor(computer, pcHighlights[computer])
            end
            
            if desc:IsA("BasePart") then
                local conn = desc:GetPropertyChangedSignal("Color"):Connect(function()
                    if pcHighlights[computer] and pcHighlights[computer].Parent then
                        updatePCHighlightColor(computer, pcHighlights[computer])
                    end
                end)
                table.insert(connections, conn)
            end
            
            if desc:IsA("ValueBase") then
                local conn = desc.Changed:Connect(function()
                    if pcHighlights[computer] and pcHighlights[computer].Parent then
                        updatePCHighlightColor(computer, pcHighlights[computer])
                    end
                end)
                table.insert(connections, conn)
            end
        end)
        table.insert(connections, childAddedConn)
        
        pcStatusConnections[computer] = connections
        
        return h
    end)
    
    if success then
        pcHighlights[computer] = hl
    end
end

print("ESP PC: Encontrados " .. #computers .. " computadores")

end
